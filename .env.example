# --- PRIMARY UNIFIED KEYS ---
VENICE_API_KEY=your_venice_api_key_here
AISA_API_KEY=your_aisa_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
COMPOSIO_API_KEY=your_composio_api_key_here

# Tabstack provides deep web extraction (Markdown) and meta-research.
TABSTACK_API_KEY=your_tabstack_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
SYNTHDATA_API_KEY=your_synthdata_api_key_here
SERPAPI_API_KEY=your_serpapi_key_here

# --- OPTIONAL FALLBACKS (If AISA is not used) ---
RAPIDAPI_KEY=your_rapidapi_key_here
GEMINI_API_KEY=your_gemini_api_key_here
NEWSAPI_KEY=your_newsapi_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- DATABASE & SYSTEM ---
DATABASE_URL=sqlite:///./trends.db
REDIS_URL=redis://localhost:6379

# --- APP CONFIG ---
DEBUG=true
FRONTEND_URL=http://localhost:3000
X402_RECIPIENT_ADDRESS=0xYourWalletAddress

# --- CHAINLINK FUNCTIONS (Multichain) ---
# Active chain: "base-sepolia" or "arbitrum-sepolia"
CHAINLINK_ACTIVE_CHAIN=base-sepolia
CHAINLINK_RPC_URL=https://sepolia.base.org
CHAINLINK_WALLET_PRIVATE_KEY=0x...
CHAINLINK_SUBSCRIPTION_ID=
CHAINLINK_CONSUMER_ADDRESS=
CHAINLINK_ORACLE_ADDRESS=
# Foundry deploy RPC endpoints
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# --- PAYMENTS & MONAD ---
REQUIRE_X402=false
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
MONAD_EXPLORER_URL=https://testnet.monadexplorer.com
X402_PAYMENT_AMOUNT=0.001

# Rate limiting tiers (searches per day)
FREE_TIER_DAILY_LIMIT=3
CONNECTED_TIER_DAILY_LIMIT=10

# Research resiliency
RESEARCH_CONNECTOR_RETRIES=2
RESEARCH_CONNECTOR_BACKOFF_SECS=0.8
SERPAPI_TIMEOUT_SECS=20

# SynthData endpoint resiliency
SYNTHDATA_RETRY_BACKOFF_SECS=0.8
SYNTHDATA_PREDICTION_RETRIES=2
SYNTHDATA_VOLATILITY_RETRIES=2
SYNTHDATA_OPTIONS_RETRIES=2
SYNTHDATA_LIQUIDATION_RETRIES=2
SYNTHDATA_POLYMARKET_RETRIES=2
ENABLE_PODCAST_ACTION=false

# --- ATTESTATION ---
# eigencompute (Production) | local_hmac (Dev)
ATTESTATION_PROVIDER=local_hmac
ATTESTATION_STRICT_MODE=true
ATTESTATION_DEV_SECRET=replace_me_dev_secret
ATTESTATION_KEY_ID=local-dev-key

# Optional when ATTESTATION_PROVIDER=eigencompute
EIGEN_ATTEST_URL=https://eigen-attest.famile.xyz/attest
EIGEN_HEALTH_URL=https://eigen-attest.famile.xyz/health
EIGEN_ATTEST_TOKEN=replace_me_secure_token
EIGEN_ATTEST_TIMEOUT_SECS=10
EIGEN_ATTEST_RETRIES=3
EIGEN_ATTEST_BACKOFF_MS=300
