# --- PRIMARY UNIFIED KEYS ---
VENICE_API_KEY=your_venice_api_key_here
AISA_API_KEY=your_aisa_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
COMPOSIO_API_KEY=your_composio_api_key_here

# Tabstack provides deep web extraction (Markdown) and meta-research.
TABSTACK_API_KEY=your_tabstack_api_key_here

# --- OPTIONAL FALLBACKS (If AISA is not used) ---
RAPIDAPI_KEY=your_rapidapi_key_here
GEMINI_API_KEY=your_gemini_api_key_here
NEWSAPI_KEY=your_newsapi_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- DATABASE & SYSTEM ---
DATABASE_URL=sqlite:///./trends.db
REDIS_URL=redis://localhost:6379

# --- APP CONFIG ---
DEBUG=true
FRONTEND_URL=http://localhost:3000
X402_RECIPIENT_ADDRESS=0xYourWalletAddress

# --- PAYMENTS (Optional for local dev) ---
REQUIRE_X402=false

# --- ATTESTATION ---
# local_hmac (default) | eigencompute
ATTESTATION_PROVIDER=local_hmac
ATTESTATION_DEV_SECRET=replace_me_dev_secret
ATTESTATION_KEY_ID=local-dev-key

# Optional when ATTESTATION_PROVIDER=eigencompute
EIGEN_ATTEST_URL=
EIGEN_ATTEST_TOKEN=
