# ACP (Agent Commerce Protocol) Configuration
# Copy this to your .env file and fill in the values

# Enable/disable ACP integration
ACP_ENABLED=false

# Agent wallet address (from ACP platform registration)
# This is the smart wallet address created for your agent
ACP_AGENT_WALLET_ADDRESS=

# Wallet private key (whitelisted developer wallet)
# This is the private key of your whitelisted wallet that can control the agent wallet
ACP_WALLET_PRIVATE_KEY=

# Entity ID (from ACP platform registration)
# This is your agent's unique identifier in the ACP system
ACP_ENTITY_ID=

# Service pricing (in USDC)
ACP_SERVICE_PRICE=10.00

# Service Level Agreement (in seconds)
# Maximum time to complete a research job
ACP_SERVICE_SLA_SECONDS=180

# Network configuration (Base mainnet)
# These are typically set by the SDK, but can be overridden
# ACP_NETWORK=base
# ACP_RPC_URL=https://mainnet.base.org
